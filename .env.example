# Shannon-py Environment Configuration
# 复制本文件为 .env 并填入凭证。所有变量均以代码为准
# (packages/core/src/shannon_core/agents/providers*.py)。
# .env 启动时以 override=True 加载，优先级高于 shell 环境变量。

# =============================================================================
# 1. 鉴权（按场景三选一）
# =============================================================================

# (a) API Key — x-api-key 方式：Anthropic 官方及大部分兼容接口
ANTHROPIC_API_KEY=your-api-key-here
# 显式覆盖（优先级高于 ANTHROPIC_API_KEY）：
# SHANNON_API_KEY=...

# (b) Bearer Token — 第三方 Anthropic 兼容接口（智谱 / DeepSeek 等自建网关）
# 必须用 ANTHROPIC_* 前缀才会透传给 Claude CLI；SHANNON_AUTH_TOKEN 仅 litellm_router 生效。
# ANTHROPIC_BASE_URL=https://your-anthropic-compatible-endpoint
# ANTHROPIC_AUTH_TOKEN=your-bearer-token

# (c) OAuth — Claude Code 订阅账号
# CLAUDE_CODE_OAUTH_TOKEN=...

# =============================================================================
# 2. Provider 类型与端点
# =============================================================================
# 可选: anthropic_api(默认) | bedrock | vertex | openai_compatible | litellm_router
# SHANNON_AI_PROVIDER=anthropic_api
# 覆盖端点（openai_compatible / litellm_router 走此 config.base_url；fallback: ANTHROPIC_BASE_URL）
# SHANNON_BASE_URL=https://your-endpoint

# =============================================================================
# 3. 模型分层（优先级: SHANNON_*_MODEL > SHANNON_MODEL > 内置默认）
# =============================================================================
# SHANNON_MODEL=...                         # 全局（fallback: ANTHROPIC_MODEL）
# SHANNON_LARGE_MODEL=claude-opus-4-8
# SHANNON_MEDIUM_MODEL=claude-sonnet-4-6
# SHANNON_SMALL_MODEL=claude-haiku-4-5-20251001

# =============================================================================
# 4. AWS Bedrock
# =============================================================================
# SHANNON_AI_PROVIDER=bedrock
# AWS_REGION=us-east-1            # fallback 链: SHANNON_REGION > AWS_REGION > CLOUD_ML_REGION
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_BEARER_TOKEN_BEDROCK=...    # 可选 Bearer 方式

# =============================================================================
# 5. Google Vertex AI
# =============================================================================
# SHANNON_AI_PROVIDER=vertex
# SHANNON_PROJECT_ID=...          # fallback: ANTHROPIC_VERTEX_PROJECT_ID
# SHANNON_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# =============================================================================
# 6. OpenAI 兼容 / LiteLLM Router
# =============================================================================
# SHANNON_AI_PROVIDER=openai_compatible
# SHANNON_API_KEY=...             # fallback: OPENAI_API_KEY
# SHANNON_BASE_URL=https://your-openai-endpoint
# SHANNON_MODEL=gpt-4o
#
# SHANNON_AI_PROVIDER=litellm_router
# SHANNON_BASE_URL=https://your-litellm-endpoint
# SHANNON_AUTH_TOKEN=your-litellm-token   # 仅此 provider 认 auth_token

# =============================================================================
# 7. Claude Agent SDK 行为
# =============================================================================
# CLAUDE_CODE_MAX_OUTPUT_TOKENS=64000     # 单次输出最大 token（默认 64000）
# CLAUDE_ADAPTIVE_THINKING=true           # adaptive thinking（默认启用）
# PLAYWRIGHT_MCP_EXECUTABLE_PATH=/path/to/chromium

# =============================================================================
# 8. Temporal
# =============================================================================
# TEMPORAL_ADDRESS=localhost:7233

# =============================================================================
# 9. 路径与浏览器
# =============================================================================
# SHANNON_DELIVERABLES_SUBDIR=.shannon/deliverables   # 产出物子目录（默认值）
# SHANNON_WORKER_ROOT=/path/to/worker/root            # Worker 基准目录
# SHANNON_BROWSER_ENGINE=playwright                   # playwright(默认) | agent-browser
