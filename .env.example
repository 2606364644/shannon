# Shannon-py AI Provider Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# AI Provider Configuration
# ============================================================================

# AI Provider selection
# Options: anthropic_api, bedrock, vertex, openai_compatible, litellm_router
SHANNON_AI_PROVIDER=anthropic_api

# API Key (unified for all providers)
# For Anthropic: use your Anthropic API key
# For OpenAI-compatible: use your provider's API key
SHANNON_API_KEY=your-api-key-here

# Alternative: Use the legacy ANTHROPIC_API_KEY (SHANNON_API_KEY takes precedence)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Base URL for API calls (optional)
# For Anthropic: https://api.anthropic.com (default)
# For OpenAI-compatible: your provider's endpoint
# SHANNON_BASE_URL=https://your-endpoint

# Optional: Override default model name
# Anthropic: claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-8
# OpenAI-compatible: gpt-4o-mini, gpt-4o, etc.
# SHANNON_MODEL=claude-sonnet-4-6

# ============================================================================
# Provider-specific Configuration
# ============================================================================

# AWS Bedrock Configuration (when SHANNON_AI_PROVIDER=bedrock)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Google Cloud Vertex AI Configuration (when SHANNON_AI_PROVIDER=vertex)
# SHANNON_PROJECT_ID=your-project-id
# SHANNON_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# LiteLLM Router Configuration (when SHANNON_AI_PROVIDER=litellm_router)
# SHANNON_AUTH_TOKEN=your-litellm-token

# ============================================================================
# Claude Agent Configuration
# ============================================================================

# Enable/disable adaptive thinking (default: true)
# CLAUDE_ADAPTIVE_THINKING=true

# ============================================================================
# Temporal Configuration
# ============================================================================

# Temporal Server address (default: localhost:7233)
# TEMPORAL_ADDRESS=localhost:7233

# ============================================================================
# Development Options
# ============================================================================

# Enable debug logging
# SHANNON_DEBUG=false

# Maximum budget in USD per agent run (optional)
# SHANNON_MAX_BUDGET=1.0
